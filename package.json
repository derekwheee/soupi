{
    "private": true,
    "name": "soupi",
    "version": "1.4.0",
    "license": "MIT",
    "scripts": {
        "start": "ts-node src/server.ts",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "dist": "node src/server.js",
        "build": "tsc -p tsconfig.json",
        "lint": "eslint .",
        "docker:rebuild": "tsc -p tsconfig.json && docker rm -f soupi || true && docker build -t soupi . && docker run -d -p 8080:8080 --env-file .env-docker --name soupi soupi",
        "migrate": "prisma migrate deploy",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "studio": "prisma studio",
        "db:reset": "prisma migrate reset --force",
        "test:ui": "vitest --ui",
        "prepare": "husky"
    },
    "imports": {
        "#*": "./src/*"
    },
    "dependencies": {
        "@ai-sdk/openai": "^2.0.53",
        "@clerk/express": "^1.7.37",
        "@prisma/client": "6.9.0",
        "@prisma/extension-accelerate": "2.0.2",
        "ai": "^5.0.76",
        "axios": "^1.12.2",
        "cheerio": "^1.1.2",
        "cors": "^2.8.5",
        "express": "5.1.0",
        "express-rate-limit": "^8.3.2",
        "he": "^1.2.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "puppeteer": "^24.25.0",
        "superjson": "^2.2.5",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@types/cors": "^2.8.19",
        "@types/express": "5.0.3",
        "@types/he": "^1.2.3",
        "@types/node": "22.15.32",
        "@types/pino-http": "^5.8.4",
        "@vitest/coverage-v8": "^4.1.2",
        "@vitest/ui": "^4.1.2",
        "dotenv": "^17.2.3",
        "eslint": "^9.36.0",
        "eslint-plugin-perfectionist": "^4.15.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.10",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.6.2",
        "prisma": "6.9.0",
        "ts-node": "10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "5.8.2",
        "typescript-eslint": "^8.45.0",
        "vitest": "^4.1.2",
        "vitest-mock-extended": "^3.1.0"
    },
    "prisma": {
        "schema": "./prisma/schema",
        "seed": "ts-node prisma/seed.ts"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md,yml}": [
            "prettier --write"
        ]
    }
}
