# soupi environment — copy to .env and fill in.
# Loaded at startup via dotenv; validated by src/env.ts (the server refuses to
# boot if a required var is missing).

# ── Database (Prisma) ────────────────────────────────────────────────────────
# DATABASE_URL is the active connection.
#   - Prisma Postgres + Accelerate looks like: prisma+postgres://accelerate.prisma-data.net/?api_key=...
#   - A self-hosted/direct Postgres looks like: postgresql://user:password@host:5432/soupi
DATABASE_URL=postgresql://user:password@localhost:5432/soupi

# Optional per-environment references — point DATABASE_URL at the right one.
# DEV_DATABASE_URL=
# PROD_DATABASE_URL=
# DEV_POSTGRES_URL=
# PROD_POSTGRES_URL=

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Use the matching instance per environment (test keys for dev, live for prod).
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── OpenAI (recipe suggestions + expiry estimates; /ai routes) ───────────────
OPENAI_API_KEY=sk-...

# ── Python NLP ingredient parser ─────────────────────────────────────────────
# Optional locally, but required to populate parsed ingredient "item" fields.
NLP_PYTHON_PATH=./python/venv/bin/python
NLP_PARSER_PATH=./python/parser.py

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=development            # set to "production" in deployed environments
LOG_LEVEL=info                  # fatal | error | warn | info | debug | trace

# Comma-separated CORS allowlist. If unset, all origins are allowed (dev only).
# CORS_ORIGINS=https://sous.example.com,http://localhost:5173

# ── App config ───────────────────────────────────────────────────────────────
EXPIRATION_WINDOW_DAYS=4

# ── Seeding (prisma db seed) ─────────────────────────────────────────────────
# Your Clerk user id; the seed creates a household/pantry/recipes for it.
# SEED_USER_ID=user_...
