# Per-environment deploy config. Copy to .env.dev and .env.prod (one each), fill
# in, then deploy:
#   npm run deploy dev        # or: docker compose --env-file .env.dev up -d --build
#   npm run deploy prod
# These files are gitignored. The values here are CONTAINER runtime env AND
# compose interpolation vars (ENV, POSTGRES_*, API_PORT).

# Selects the stack (container/volume/network names get this suffix).
ENV=dev

# ── Postgres (self-hosted; runs in the `db` service) ─────────────────────────
POSTGRES_USER=soupi
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=soupi_dev

# Prisma connects to the db service over the compose network (host = db).
# Keep user/password/db in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://soupi:change-me-strong@db:5432/soupi_dev

# ── Auth (Clerk) ─ test keys for dev, live keys for prod ─────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Python NLP parser (paths INSIDE the container) ───────────────────────────
NLP_PYTHON_PATH=/opt/venv/bin/python
NLP_PARSER_PATH=/app/python/parser.py

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
# localhost-only host port for smoke tests; use different ports per env on one host
# (e.g. dev 8080, prod 8081).
API_PORT=8080
# Comma-separated CORS allowlist (the deployed sous-web origin(s)).
CORS_ORIGINS=https://sous.example.com
# Run `prisma migrate deploy` on container start.
RUN_MIGRATIONS=true

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Ingress (Zero Trust) should point at http://soupi_${ENV}_api:8080
TUNNEL_TOKEN=

# ── App config ───────────────────────────────────────────────────────────────
EXPIRATION_WINDOW_DAYS=4
